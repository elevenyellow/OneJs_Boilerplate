model Zone {
  id            String   @id @default(uuid())
  name          String
  description   String   @db.Text
  country       String
  region        String
  latitude      Float
  longitude     Float
  climbingTypes String[]
  gradeRange    Json
  stats         Json
  totalRoutes   Int      @default(0)
  theCragUrl    String   @unique
  imageUrl      String?
  altitude      Int?
  approach      String?  @db.Text
  bestSeasons   String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([country])
  @@index([region])
  @@index([latitude, longitude])
  @@index([totalRoutes])
}


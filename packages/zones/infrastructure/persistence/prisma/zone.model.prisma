model Zone {
  id         String @id @default(uuid())
  externalId String @unique

  // Identificación
  name      String
  asciiName String?
  type      String

  // URLs
  href            String? // ← NUEVO: URL completa del breadcrumb
  urlStub         String?
  urlAncestorStub String?
  position        Int? // ← NUEVO: Posición en breadcrumb

  // Jerarquía (auto-referencia)
  parentId String?
  parent   Zone?   @relation("ZoneHierarchy", fields: [parentId], references: [id])
  children Zone[]  @relation("ZoneHierarchy")

  // Profundidad en la jerarquía (0 = World, 1 = Country, etc.)
  depth Int @default(0)

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones con otros modelos
  crags Crag[]

  // Índices para consultas rápidas
  @@index([parentId])
  @@index([type])
  @@index([depth])
  @@index([name])
  @@index([position]) // ← NUEVO índice
}

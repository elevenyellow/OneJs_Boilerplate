model Route {
  id         String @id @default(uuid())
  externalId String @unique

  // Identificación
  name            String
  urlAncestorStub String?

  // === GRADO (muy importante para filtros) ===
  grade          String?
  gradeBand      Int
  gradeStyle     String?
  gradeInContext String? // Grade in geographic context
  rawGradeMin    Int?
  rawGradeMax    Int?

  // === DIMENSIONES ===
  height     Float?
  heightUnit String?
  pitches    Int?

  // === CALIDAD (para ordenar "mejores rutas") ===
  stars Int?

  // === POPULARIDAD (para ordenar) ===
  ascents    Int?
  popularity Float?

  // === ESTILO Y EQUIPAMIENTO ===
  style String?
  bolts Int?

  // === PRIMERA ASCENSIÓN ===
  firstAscent String?
  equipper    String?
  equipDate   String?
  maintainer  String?
  maintDate   String?

  // === DESCRIPCIÓN ===
  description     String?
  descriptionHtml String?

  // === ESTILO (bitmask para filtros rápidos) ===
  // Bit 0 (1): Sport, Bit 1 (2): Trad, Bit 2 (4): Boulder, Bit 3 (8): Aid
  // Bit 4 (16): Alpine, Bit 5 (32): Mixed, Bit 6 (64): Ice, Bit 7 (128): TopRope
  styleFlags Int @default(0)

  // === ESTADO ===
  isClosed    Boolean @default(false)
  hasWarning  Boolean @default(false)
  warningText String?

  // === TOPO ===
  hasTopo    Boolean @default(false)
  topoNumber String?

  // === JERARQUÍA ===
  siblingLabel     Int?
  depth            Int?
  sectorId         String?
  cragId           String
  externalParentId String?

  // === METADATA ===
  tags     Json?
  warnings Json?
  akaNames String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sector          Sector?          @relation(fields: [sectorId], references: [id])
  crag            Crag             @relation(fields: [cragId], references: [id])
  topoAnnotations TopoAnnotation[]
  userAscents     Ascent[]         @relation("userAscents")

  // === ÍNDICES PARA CONSULTAS DE GUÍA ===
  @@index([cragId])
  @@index([sectorId])
  @@index([gradeBand])
  @@index([stars])
  @@index([styleFlags])
  @@index([height])
  @@index([bolts])
  @@index([popularity])
  @@index([cragId, gradeBand])
  @@index([cragId, stars])
  @@index([sectorId, siblingLabel])
  @@index([externalParentId])
}

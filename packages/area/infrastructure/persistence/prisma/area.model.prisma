model Area {
  id           String   @id @default(cuid())
  externalId   BigInt   @unique
  cragId       String
  parentAreaId String?  // Para áreas anidadas (Cliff dentro de Area)
  name         String
  altNames     String[] // Nombres alternativos
  type         String   // Area, Cliff
  latitude     Float?
  longitude    Float?
  geometry     Json?
  beta         Json?    // [{name, markdown}]
  
  // Información temporal
  seasonality  Int[]    // Seasonality también para áreas
  
  // Campos adicionales de TheCrag
  locatedness     Int?     // Precisión GPS (0-100)
  averageHeight   Float?   // Altura promedio de rutas
  numberRoutes    Int?     // Total de rutas en el área
  permitNode      Json?    // Información de permisos
  priceCategory   String?  // Categoría de precio
  urlAncestorStub String?  // URL ancestral
  redirectStubs   String[] @default([]) // URLs alternativas
  tlc             Json?    // Top Level Crag reference
  
  // API Response Raw (para análisis futuro)
  apiResponseRaw Json?  // Respuesta completa de la API

  // Imagen de cabecera - URLs originales de TheCrag
  headerImageUrl    String?
  headerImageWidth  Int?
  headerImageHeight Int?

  // Imagen de cabecera - URLs S3 optimizadas
  headerImageS3Url       String?
  headerImageS3UrlFull   String?
  headerImageOriginalUrl String?

  crag       Crag   @relation(fields: [cragId], references: [id], onDelete: Cascade)
  parentArea Area?  @relation("AreaHierarchy", fields: [parentAreaId], references: [id])
  childAreas Area[] @relation("AreaHierarchy")
  sectors    Sector[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cragId])
  @@index([parentAreaId])
  @@map("areas")
}

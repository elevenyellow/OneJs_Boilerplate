/// Weather forecast data scraped from meteoblue
/// Stores both daily and hourly forecasts for climbing zones
model WeatherForecast {
  id            String   @id @default(cuid())
  zoneId        String   @map("zone_id")
  date          DateTime
  hour          Int?     @default(-1) // -1 for daily forecasts, 0-23 for hourly
  tempMin       Float    @map("temp_min")
  tempMax       Float    @map("temp_max")
  tempCurrent   Float?   @map("temp_current")
  rainProb      Int      @map("rain_prob") // Percentage 0-100
  windSpeed     Float    @map("wind_speed") // km/h
  windDirection String?  @map("wind_direction") // N, NE, E, SE, S, SW, W, NW
  humidity      Int      // Percentage 0-100
  condition     String   // sunny, cloudy, rain, etc.
  conditionIcon String?  @map("condition_icon") // Icon URL from meteoblue
  uvIndex       Int?     @map("uv_index") // 0-11+
  fetchedAt     DateTime @default(now()) @map("fetched_at")

  @@unique([zoneId, date, hour], name: "zoneId_date_hour")
  @@index([zoneId, date])
  @@index([zoneId, fetchedAt])
  @@map("weather_forecasts")
}



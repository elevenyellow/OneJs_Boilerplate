model Crag {
  id          String   @id @default(cuid())
  externalId  BigInt   @unique
  countryId   String
  regionId    String?
  name        String
  altNames    String[] // Nombres alternativos
  latitude    Float?
  longitude   Float?
  geometry    Json? // {boundary, bbox, center, areasize}
  locatedness Int? // Precisión de coordenadas 0-100

  // Información temporal
  seasonality Int[] // [215, 117, 103, ...] - 12 meses + extra

  // Beta / Información descriptiva
  description String? @db.Text
  approach    String? @db.Text
  ethic       String? @db.Text

  // Estadísticas de TheCrag (ALTA PRIORIDAD)
  numberPhotos   Int? // Número de fotos
  numberTopos    Int? // Número de topos/croquis
  hasTopo        Boolean @default(false)
  totalFavorites Int? // Total de favoritos (popularidad)
  kudos          Int? // Kudos recibidos

  // Estadísticas adicionales (MEDIA PRIORIDAD)
  ascentCount Int? // Número total de ascensos
  maxPop      Int? // Popularidad máxima (métrica TheCrag)

  // Metadata de TheCrag
  priceCategory String? // Categoría de precio
  permitNode    Json? // Información sobre permisos necesarios
  tagsRaw       Json? // Tags originales de TheCrag sin procesar

  // URLs de TheCrag (ALTA PRIORIDAD)
  sourceUrl       String // URL principal
  urlStub         String? // URL stub en TheCrag
  urlAncestorStub String?

  // Imagen de cabecera - URLs originales de TheCrag
  headerImageUrl    String? // URL de la imagen principal del crag (TheCrag)
  headerImageWidth  Int?
  headerImageHeight Int?

  // Imagen de cabecera - URLs S3 optimizadas
  headerImageS3Url       String? // URL S3 optimizada (800px, WebP)
  headerImageS3UrlFull   String? // URL S3 original (WebP)
  headerImageOriginalUrl String? // URL original de TheCrag (backup/referencia)

  // Imagen de overview (topo general mostrando sectores)
  overviewTopoImageUrl    String? // URL de la imagen del topo general
  overviewTopoThumbnailUrl String? // URL del thumbnail
  overviewTopoWidth       Int?
  overviewTopoHeight      Int?
  overviewTopoExternalId  String? // ID externo del topo (para referencia a CragTopoImage)

  // PDF Info (MEDIA PRIORIDAD)
  lastPDFSize       String?
  lastPDFStaticDate String?

  // Campos adicionales de TheCrag
  averageHeight     Float? // Altura promedio de rutas
  numberRoutes      Int? // Total de rutas en el crag
  subAreaCount      Int? // Número de sub-áreas
  redirectStubs     String[] @default([]) // URLs alternativas
  tlc               Json? // Top Level Crag reference
  lastPDFStaticSize String? // Tamaño del PDF estático

  // API Response Raw (para análisis futuro)
  apiResponseRaw Json? // Respuesta completa de la API

  country    Country         @relation(fields: [countryId], references: [id])
  region     Region?         @relation(fields: [regionId], references: [id])
  areas      Area[]
  topoImages CragTopoImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([countryId])
  @@index([regionId])
  @@index([latitude, longitude])
  @@index([totalFavorites])
  @@index([numberPhotos])
  @@index([hasTopo])
  @@map("crags")
}

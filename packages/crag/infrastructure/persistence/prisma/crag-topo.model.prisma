// CragTopoImage - Overview topo image for a crag showing sectors
model CragTopoImage {
  id             String   @id @default(cuid())
  externalId     String   @unique // TheCrag topoId
  cragId         String

  // Image URLs - TheCrag originals
  thumbnailUrl   String
  fullImageUrl   String

  // Image URLs - S3 optimized
  thumbnailS3Url    String? // URL S3 thumbnail (800px, WebP)
  fullImageS3Url    String? // URL S3 full size (WebP)
  originalSourceUrl String? // URL original de TheCrag (backup/referencia)

  // Dimensions
  width          Int
  height         Int
  originalWidth  Int
  originalHeight Int
  viewScale      Float    @default(1.0)

  // Metadata
  sourceUrl      String?  // Link to original topo page

  // Relations
  crag            Crag                     @relation(fields: [cragId], references: [id], onDelete: Cascade)
  sectorPositions CragTopoSectorPosition[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cragId])
  @@map("crag_topo_images")
}

// CragTopoSectorPosition - Links a sector to its position on a crag topo image
model CragTopoSectorPosition {
  id             String  @id @default(cuid())
  sectorId       String? // Optional - may not match a sector in DB yet
  cragTopoId     String

  // Position data
  areaNumber     String  // Display number on this topo (e.g., "1", "2")
  areaName       String  // Name of the sector/area
  points         String  // SVG path points: "x1 y1,x2 y2,..."
  zindex         Int     @default(0)
  order          Int     @default(0)

  // External reference
  externalAreaId BigInt? // TheCrag area ID for matching
  areaUrl        String? // URL to the sector on TheCrag

  // Relations
  sector   Sector?       @relation(fields: [sectorId], references: [id], onDelete: SetNull)
  cragTopo CragTopoImage @relation(fields: [cragTopoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([cragTopoId, externalAreaId])
  @@index([sectorId])
  @@index([cragTopoId])
  @@map("crag_topo_sector_positions")
}

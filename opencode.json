{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-opus-4.7",
  "agent": {
    "explore": {
      "description": "Thinking partner. Investigates the codebase, clarifies requirements, and prepares the ground for a proposal. Does NOT write code or final specs.",
      "mode": "primary",
      "model": "github-copilot/claude-opus-4.7",
      "temperature": 0.7,
      "reasoningEffort": "high",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "task": "allow"
      },
      "prompt": "{file:./.agents/skills/openspec-explore/SKILL.md}"
    },
    "propose": {
      "description": "OpenSpec propose mode. Generates the full change folder (proposal.md, design.md, specs/, tasks.md) under openspec/changes/<id>/. Loads the openspec-propose skill. Only writes inside openspec/.",
      "mode": "primary",
      "model": "github-copilot/claude-opus-4.7",
      "temperature": 0.2,
      "reasoningEffort": "high",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "task": "allow"
      },
      "prompt": "{file:./.agents/skills/openspec-propose/SKILL.md}"
    },
    "apply": {
      "description": "OpenSpec apply mode. Implements tasks from an existing change following hexagonal architecture and TDD. Loads the openspec-apply-change skill. ALWAYS reads openspec/changes/<id>/ before editing code.",
      "mode": "primary",
      "model": "github-copilot/claude-sonnet-4.5",
      "temperature": 0.2,
      "reasoningEffort": "medium",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "task": "allow"
      },
      "prompt": "{file:./.agents/skills/openspec-apply-change/SKILL.md}"
    },
    "archive": {
      "description": "OpenSpec archive mode. Closes an implemented change: updates canonical specs, moves the change to archive/, and validates.",
      "mode": "primary",
      "model": "github-copilot/claude-sonnet-4.5",
      "temperature": 0.1,
      "reasoningEffort": "medium",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "task": "allow"
      },
      "prompt": "{file:./.agents/skills/openspec-archive-change/SKILL.md}"
    },
    "review": {
      "description": "OpenSpec review mode. Runs the full review gate before archive: invokes code/tests/architecture/frontend reviewers in parallel, consolidates findings, applies fixes, and validates with project-validator until green. Sits between `apply` and `archive`.",
      "mode": "primary",
      "model": "github-copilot/claude-sonnet-4.5",
      "temperature": 0.2,
      "reasoningEffort": "high",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "task": "allow"
      },
      "prompt": "{file:./.agents/skills/openspec-review/SKILL.md}"
    },
    "spec-writer": {
      "description": "Drafts a single OpenSpec artifact (proposal.md, design.md, spec delta, or tasks.md) for a given change id. Read-only on production code; writes only inside openspec/.",
      "mode": "subagent",
      "model": "github-copilot/claude-sonnet-4.5",
      "temperature": 0.1,
      "reasoningEffort": "low",
      "permission": {
        "edit": "allow",
        "bash": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow"
      },
      "prompt": "{file:./.agents/agents/spec-writer.md}"
    },
    "spec-reviewer": {
      "description": "Reviews an OpenSpec change folder for completeness, internal consistency, and alignment with project conventions. Read-only.",
      "mode": "subagent",
      "model": "github-copilot/claude-sonnet-4.5",
      "temperature": 0.2,
      "reasoningEffort": "high",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow"
      },
      "prompt": "{file:./.agents/agents/spec-reviewer.md}"
    },
    "code-reviewer": {
      "description": "Reviews production code in a scoped diff against design, naming, and error-handling conventions. Applies fixes inside the scope.",
      "mode": "subagent",
      "model": "github-copilot/claude-sonnet-4.5",
      "temperature": 0.2,
      "reasoningEffort": "high",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow"
      },
      "prompt": "{file:./.agents/agents/code-reviewer.md}"
    },
    "tests-reviewer": {
      "description": "Reviews test quality and coverage inside a scoped diff. Fixes low-ambiguity issues and adds missing tests when behavior is clear.",
      "mode": "subagent",
      "model": "github-copilot/claude-sonnet-4.5",
      "temperature": 0.2,
      "reasoningEffort": "medium",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow"
      },
      "prompt": "{file:./.agents/agents/tests-reviewer.md}"
    },
    "architecture-reviewer": {
      "description": "Reviews hexagonal/DDD architecture compliance inside a scoped diff and fixes violations.",
      "mode": "subagent",
      "model": "github-copilot/claude-sonnet-4.5",
      "temperature": 0.2,
      "reasoningEffort": "high",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow"
      },
      "prompt": "{file:./.agents/agents/architecture-reviewer.md}"
    },
    "frontend-reviewer": {
      "description": "Reviews frontend changes (apps/webapp, apps/mobile) for component, hook, routing, and tRPC integration issues.",
      "mode": "subagent",
      "model": "github-copilot/claude-sonnet-4.5",
      "temperature": 0.2,
      "reasoningEffort": "medium",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow"
      },
      "prompt": "{file:./.agents/agents/frontend-reviewer.md}"
    },
    "project-validator": {
      "description": "Runs full project validation (lint, typecheck, tests), fixes issues, and re-runs until clean.",
      "mode": "subagent",
      "model": "github-copilot/claude-sonnet-4.5",
      "temperature": 0,
      "reasoningEffort": "low",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow"
      },
      "prompt": "{file:./.agents/agents/project-validator.md}"
    }
  },
  "instructions": [
    "AGENTS.md",
    ".agents/skills/guidelines/git-strategy/SKILL.md"
  ],
  "mcp": {
    "postgres": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "{env:DDD_FULLSTACK_STARTER_DATABASE_URL}"
      ],
      "enabled": true
    }
  }
}

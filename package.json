{
  "name": "ey-js-boilerplate",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "create-app": "bun ./packages/create-app/cli.ts",
    "start:db": "podman-compose down && podman rm -f postgresdb || true && podman-compose up -d",
    "start:dev": "bun start:db && bun --verbose --watch index.ts",
    "start:dev:simple": "bun --verbose --watch index.ts",
    "start": "bun run index.ts",
    "test": "bun --test",
    "prisma:merge": "bun run scripts/merge-schema.ts",
    "prisma:generate": "bun run prisma:merge && bunx prisma validate && bunx prisma generate  --schema=./schema.prisma",
    "prisma:migrate": "bunx prisma migrate dev",
    "prisma:studio": "bunx prisma studio",
    "prisma:push": "bunx prisma db push",
    "prisma:migrate:prod": "bunx prisma migrate deploy",
    "prisma:push:prod": "bunx prisma db push"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prisma": "6.8.1",
    "prisma-merge": "^0.2.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {}
}

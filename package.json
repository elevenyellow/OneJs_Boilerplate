{
  "name": "ey-js-boilerplate",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "create-app": "bun ./packages/create-app/cli.ts",
    "start:db": "podman-compose down && podman rm -f postgresdb || true && podman-compose up -d",
    "start:dev": "bun start:db && bun --verbose --watch index.ts",
    "start:dev:api": "bun start:db && cd apps/api && bun --verbose --watch index.ts",
    "start:dev:simple": "bun --verbose --watch index.ts",
    "start": "bun run index.ts",
    "test": "bun --test",
    "prisma:merge": "bun scripts/merge-schema.ts",
    "prisma:validate": "bunx prisma validate",
    "prisma:generate": "bunx prisma generate",
    "prisma:build": "bun scripts/merge-schema.ts && bunx prisma validate && bunx prisma generate"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prisma": "^6.8.1",
    "prisma-merge": "^0.2.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}

{
  "name": "one-js-boilerplate",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": [],
  "scripts": {
    "init": "bun scripts/init.ts",
    "postinstall": "npx prisma generate --schema=./prisma/schema.prisma",
    "create-app": "bun ./.oneJs/create-app/cli.ts",
    "start:db": "podman-compose down > /dev/null 2>&1 && (podman rm -f postgresdb > /dev/null 2>&1 || true) && podman-compose up -d > /dev/null 2>&1",
    "prisma:merge": "bun ./.oneJs/prisma/src/scripts/merge-schema.ts",
    "prisma:validate": "npx prisma validate --schema=./prisma/schema.prisma",
    "prisma:generate:dev": "npx prisma generate --schema=./prisma/schema.prisma",
    "prisma:build": "bun run prisma:merge && bun run prisma:validate && bun run prisma:generate:dev",
    "prisma:migrate:dev": "npx prisma migrate dev --name init --schema=./prisma/schema.prisma",
    "prisma:push": "npx prisma db push --schema=./prisma/schema.prisma",
    "prisma:studio": "npx prisma studio --schema=./prisma/schema.prisma",
    "prisma:generate:prod": "npx prisma generate --schema=./prisma/schema.prisma",
    "prisma:migrate:prod": "npx prisma migrate deploy --schema=./prisma/schema.prisma",
    "prisma:reset": "npx prisma migrate reset --schema=./prisma/schema.prisma",
    "test": "bun --test",
    "type-check": "tsc --noEmit",
    "start:api:prod": "bun run --cwd apps/api start",
    "start:api:dev": "bun install && bun run start:db && bun run prisma:build && bun run prisma:migrate:dev && bun run --cwd apps/api start:dev"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@types/bun": "latest",
    "@types/debug": "^4.1.12",
    "@types/jsonwebtoken": "^9.0.6"
  },
  "dependencies": {
    "@OneJs/auth": "file:./.oneJs/auth",
    "@OneJs/core": "file:./.oneJs/core",
    "@OneJs/event-bus": "file:./.oneJs/event-bus",
    "@OneJs/jobs": "file:./.oneJs/jobs",
    "@OneJs/prisma": "file:./.oneJs/prisma",
    "@OneJs/server": "file:./.oneJs/server",
    "@elysiajs/cors": "^1.4.0",
    "@elysiajs/swagger": "^1.3.1",
    "@prisma/client": "^6.17.1",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.61.0",
    "debug": "^4.0.0",
    "dotenv": "^16.0.0",
    "elysia": "^1.3.4",
    "fast-glob": "^3.3.3",
    "fast-json-parse": "^1.0.3",
    "fast-safe-stringify": "^2.1.1",
    "glob": "^11.0.2",
    "glossy": "^0.1.7",
    "moment": "^2.30.1",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "prisma": "^6.17.1",
    "pumpify": "^2.0.1",
    "split2": "^4.2.0",
    "through2": "^4.0.2",
    "typescript": "^5.0.0",
    "uuid": "^9.0.1"
  }
}
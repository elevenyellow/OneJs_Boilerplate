{
  "compilerOptions": {
    // Enable latest features
    "lib": [
      "ESNext",
      "DOM"
    ],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "paths": {
      "@*": [
        "./src/apps/*",
        "./src/common/*",
        "./packages/*"
      ],
      "@OneJs": [
        "./.oneJs"
      ],
      "@OneJs/core": [
        "./.oneJs/core/src"
      ],
      "@OneJs/core/*": [
        "./.oneJs/core/src/*"
      ],
      "@OneJs/server": [
        "./.oneJs/server/src"
      ],
      "@OneJs/server/*": [
        "./.oneJs/server/src/*"
      ],
      "@OneJs/event-bus": [
        "./.oneJs/event-bus/src"
      ],
      "@OneJs/event-bus/*": [
        "./.oneJs/event-bus/src/*"
      ],
      "@OneJs/prisma": [
        "./.oneJs/prisma/src"
      ],
      "@OneJs/prisma/*": [
        "./.oneJs/prisma/src/*"
      ],
      "@OneJs/auth": [
        "./.oneJs/auth/src"
      ],
      "@OneJs/auth/*": [
        "./.oneJs/auth/src/*"
      ],
      "@zone/*": [
        "./packages/zone/*"
      ],
      "@weather/*": [
        "./packages/weather/*"
      ],
      "@scraper/meteoblue": [
        "./packages/scraper-meteoblue"
      ],
      "@scraper/meteoblue/*": [
        "./packages/scraper-meteoblue/*"
      ],
      "@scraper-thecrag": [
        "./packages/scraper-thecrag"
      ],
      "@scraper-thecrag/*": [
        "./packages/scraper-thecrag/*"
      ],
      "@climb-zone/shared": [
        "./packages/shared"
      ],
      "@climb-zone/shared/*": [
        "./packages/shared/*"
      ],
      "@climb-zone/crag": [
        "./packages/crag"
      ],
      "@crag/*": [
        "./packages/crag/*"
      ],
      "@climb-zone/area": [
        "./packages/area"
      ],
      "@area/*": [
        "./packages/area/*"
      ],
      "@climb-zone/sector": [
        "./packages/sector"
      ],
      "@sector/*": [
        "./packages/sector/*"
      ],
      "@climb-zone/route": [
        "./packages/route"
      ],
      "@route/*": [
        "./packages/route/*"
      ],
      "@user/*": [
        "./packages/user/*"
      ],
      "@post/*": [
        "./packages/post/*"
      ],
      "@climb-zone/continent": [
        "./packages/continent"
      ],
      "@continent/*": [
        "./packages/continent/*"
      ],
      "@climb-zone/country": [
        "./packages/country"
      ],
      "@country/*": [
        "./packages/country/*"
      ],
      "@climb-zone/region": [
        "./packages/region"
      ],
      "@region/*": [
        "./packages/region/*"
      ]
    }
  }
}
    // ...
  }
}
```

### ❌ INCORRECT - Application Service with Domain Logic

```typescript
// ❌ WRONG - Domain business rules in application service
@Injectable()
export class PricingService {
  calculatePrice(
    basePrice: Money,
    duration: EventDuration,
    category: Category,
  ): Money {
    // ❌ NO - This is domain logic (business rules), should be domain service
    let price = basePrice
    if (duration.isLongerThan(EventDuration.HOURS_4)) {
      price = price.multiply(1.5) // Business rule in wrong layer
    }
    return price
  }
}
```

## Use Cases vs Application Services

### Use Cases

**Use Cases** represent **complete user interactions** or business workflows. They:
- Are the entry point from controllers/handlers
- Have a single, well-defined responsibility
- Execute one complete business operation
- May use application services for shared logic

### Application Services

**Application Services** provide **reusable application logic** shared across multiple use cases. They:
- Are used by multiple use cases
- Focus on technical orchestration
- Provide cross-cutting concerns
- Handle reusable coordination patterns

### ✅ CORRECT - Use Case Using Application Service

```typescript
// ✅ Use case: Complete user interaction
@Injectable()
export class SearchEventsUseCase {
  constructor(
    @Inject(EventSearchService) // ✅ Uses application service for reusable logic
    private readonly eventSearchService: EventSearchService,
  ) {}

  async execute(input: {
    cityId?: CityId
    categoryIds?: CategoryId[]
    search?: SearchQuery
    page: Page
    limit: Limit
  }): Promise<{ events: Event[]; total: number }> {
    // ✅ Delegates to application service
    return await this.eventSearchService.execute({
      cityId: input.cityId,
      categoryIds: input.categoryIds,
      searchQuery: input.search,
      page: input.page,
      limit: input.limit,
    })
  }
}

// ✅ Application service: Reusable search logic
@Injectable()
export class EventSearchService {
  // ... reusable search implementation
}
```

### ❌ INCORRECT - Use Case Duplicating Application Service Logic

```typescript
// ❌ WRONG - Use case duplicating logic that should be in application service
@Injectable()
export class SearchEventsUseCase {
  async execute(input: SearchEventsDto): Promise<Event[]> {
    // ❌ NO - Complex search logic duplicated in use case
    const city = input.cityId
      ? await this.cityRepository.findById(input.cityId)
      : null

    const categories = input.categoryIds
      ? await this.categoryRepository.findByIds(input.categoryIds)
      : []

    // ... duplicated logic that other use cases might need
    return await this.eventRepository.search({ ... })
  }
}
```

## Layer Separation

### ✅ CORRECT - Proper Layer Dependencies

```
Use Cases (Application)
  ├──> Application Services (Application)
  ├──> Domain Services (Domain)
  ├──> Entities (Domain)
  └──> Repositories (Infrastructure)

Domain Services (Domain)
  ├──> Entities (Domain)
  └──> Value Objects (Domain)
  ❌ Cannot depend on Application or Infrastructure

Application Services (Application)
  ├──> Domain Services (Domain)
  ├──> Entities (Domain)
  └──> Repositories (Infrastructure)
```

### ❌ INCORRECT - Layer Violations

```typescript
// ❌ WRONG - Domain service depending on infrastructure
@Injectable()
export class EventSchedulingDomainService {
  constructor(
    @Inject(EventRepository) // ❌ NO - Domain cannot depend on infrastructure
    private readonly eventRepository: EventRepository,
  ) {}

  async validateEvent(event: Event): Promise<void> {
    const existing = await this.eventRepository.findByVenue(event.getVenueId())
    // ...
  }
}

// ❌ WRONG - Application service containing domain logic
@Injectable()
export class PricingApplicationService {
  calculatePrice(/* ... */): Money {
    // ❌ NO - Business rules in application layer
    if (duration > 240) {
      price = price * 1.5
    }
  }
}
```

## Naming Conventions

### Domain Services

- File: `*.service.ts` in `domain/services/`
- Class: `*DomainService` or descriptive domain name
- Examples: `EventSchedulingDomainService`, `DiscountCalculationService`, `PricingDomainService`

### Application Services

- File: `*.service.ts` in `application/services/`
- Class: `*Service` or descriptive application name
- Examples: `EventSearchService`, `PaginationService`, `EventDetectionService`

### ✅ CORRECT - Naming

```typescript
// ✅ Domain service
// packages/events/domain/services/event-scheduling.service.ts
export class EventSchedulingDomainService {
  // Domain logic
}

// ✅ Application service
// packages/events/application/services/event-search.service.ts
export class EventSearchService {
  // Application orchestration
}
```

## Rules Summary

### ✅ DO

- Use Domain Services for business logic that spans multiple entities
- Use Domain Services for domain concepts that don't belong to entities
- Use Application Services for reusable application orchestration
- Use Application Services for cross-cutting concerns (caching, logging)
- Keep Domain Services in `domain/services/`
- Keep Application Services in `application/services/`
- Keep Domain Services pure (no infrastructure dependencies)
- Use Application Services to coordinate multiple repositories

### ❌ DON'T DO

- Don't put domain logic in Application Services
- Don't put infrastructure dependencies in Domain Services
- Don't use Domain Services for technical orchestration
- Don't duplicate logic that should be in Application Services
- Don't make Domain Services depend on repositories
- Don't make Domain Services depend on logging infrastructure
- Don't mix domain concepts with application concerns


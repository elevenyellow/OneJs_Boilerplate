    @Inject(PostRepository)
    private readonly postRepository: PostRepository,
    @Inject(Logger)
    private readonly logger: Logger,
  ) {}

  /**
   * Detects events from Instagram posts.
   * This is application orchestration, not domain logic.
   */
  async detectEventsFromPost(postId: PostId): Promise<Event[]> {
    const post = await this.postRepository.findById(postId)
    if (!post) {
      throw new OneJsError('Post not found', 404)
    }

    // ✅ Orchestrates multiple repositories and services
    const detectedEvents = await this.detectEventsInPost(post)
    
    this.logger.info('[MATO:EVENTS:DETECTION] Events detected', {
      postId: postId.toString(),
      eventCount: detectedEvents.length,
    })

    return detectedEvents
  }


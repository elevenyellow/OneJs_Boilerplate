// вң… Application service: Handles validation
@Injectable()
export class SyncUserLikesApplicationService {
  async execute(userId: UserId, eventIds: EventId[], venueIds: VenueId[]): Promise<void> {
    // Validate existence in respective contexts
    const [existingEvents, existingVenues] = await Promise.all([
      this.eventRepository.findByIds(eventIds),
      this.venueRepository.findByIds(venueIds),
    ])
    
    const validEventIds = existingEvents.map(e => e.getId())
    const validVenueIds = existingVenues.map(v => v.getId())
    
    // Use repository to store relationships
    await this.prisma.$transaction(async (tx) => {
      for (const eventId of validEventIds) {
        await this.userRepository.addEventLike(userId, eventId)
      }
      for (const venueId of validVenueIds) {
        await this.userRepository.addVenueLike(userId, venueId)
      }
    })
  }
}
```

## Migration Guide

Follow these steps to refactor existing repository violations:

### Step 1: Identify Violations

Search for Prisma queries that include tables from other contexts:

```bash
# Find include statements in repositories
grep -r "include:" packages/*/infrastructure/persistance/
```

Look for:
- `include: { event: ... }` in non-Event repositories
- `include: { venue: ... }` in non-Venue repositories
- `include: { city: ... }` in non-City repositories

### Step 2: Create Repository Methods That Return IDs Only

Refactor repository methods to return only IDs from junction tables:

```typescript
// BEFORE: Returns full event data
async getUserLikes() {
  return this.prisma.userEventLike.findMany({
    include: { event: true } // вқҢ
  })
}

// AFTER: Returns only IDs
async getUserEventLikes(userId: Id): Promise<UserEventLike[]> {
  const likes = await this.prisma.userEventLike.findMany({
    where: { userId: userId.toString() },
  })
  return likes.map(like => UserEventLike.fromDto(like))
}
```

### Step 3: Create Application Service

Create an application service to orchestrate repositories:

```typescript
// packages/user/application/services/user-likes.application-service.ts
@Injectable()
export class UserLikesApplicationService {
  constructor(
    @Inject(UserPrismaRepository)
    private readonly userRepository: UserPrismaRepository,
    @Inject(EventPrismaRepository)
    private readonly eventRepository: EventPrismaRepository,
  ) {}

  async getUserLikesWithEventDetails(userId: UserId): Promise<UserLikesDto> {
    // Get IDs from User context
    const eventLikes = await this.userRepository.getUserEventLikes(userId)
    
    // Get details from Event context
    const eventIds = eventLikes.map(like => like.getEventId())
    const events = await this.eventRepository.findByIds(eventIds)
    
    // Aggregate results
    return this.mapToDto(eventLikes, events)
  }
}
```


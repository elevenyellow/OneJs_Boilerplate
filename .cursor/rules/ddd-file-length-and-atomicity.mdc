// ❌ BAD - Use case with multiple responsibilities
@Injectable()
export class ManageEventUseCase {
  // ❌ Responsibility 1: Create event
  async create(dto: CreateEventDto): Promise<Event> { }

  // ❌ Responsibility 2: Update event
  async update(id: string, dto: UpdateEventDto): Promise<Event> { }

  // ❌ Responsibility 3: Delete event
  async delete(id: string): Promise<void> { }

  // ❌ Responsibility 4: Publish event
  async publish(id: string): Promise<void> { }

  // ❌ Should be split into separate use cases
}
```

## Exception Mechanism

Complex components may exceed standard limits with proper documentation.

### When Exceptions Are Allowed

Exceptions are permitted for:

1. **Complex Aggregates** (up to 600 LOC)
   - Multiple child entities with complex invariants
   - Extensive business rule validation
   - Complex state transitions

2. **Complex Services** (up to 500 LOC)
   - Intricate business logic that cannot be easily decomposed
   - Multiple related operations that must stay together for cohesion

3. **Complex Repositories** (up to 500 LOC)
   - Multiple complex query methods
   - Advanced filtering and pagination logic
   - Complex aggregate reconstruction from database

### Documentation Requirements

Exceptions MUST include explicit documentation at the top of the file:

```typescript
// EXCEPTION: [Component type] exceeds standard limit
// Justification: [Clear explanation of why this component needs more lines]
// LOC: [Approximate line count]
// Extraction attempts: [What was tried and why it didn't work]
// Review date: [Date when this should be reviewed for refactoring]
```

### ✅ CORRECT - Documented Exception

```typescript
// packages/events/domain/aggregates/event.ts
// EXCEPTION: Aggregate exceeds standard 500 LOC limit
// Justification: Event aggregate manages complex scheduling, pricing, and
// ticketing logic with 8+ business invariants that must be validated together.
// Child entities (EventSchedule, EventPricing, EventTickets) are tightly coupled
// and cannot be separated without breaking transactional consistency.
// LOC: ~580 lines
// Extraction attempts: Attempted to extract pricing logic to PricingService but
// it requires access to private event state for invariant validation.
// Review date: 2025-03-01

import { OneJsError } from '@OneJs/Core'
import { ErrorCodes } from '@OneJs/shared-errors'

export class Event {
  constructor(
    private readonly id: EventId,
    private readonly title: Title,
    private readonly description: Description,
    private schedule: EventSchedule,
    private pricing: EventPricing,
    private tickets: EventTickets[],
    private status: EventStatus,
  ) {}

  // Complex invariant validation spanning multiple child entities
  addTicket(ticket: EventTicket): void {
    // Validate invariant: total tickets cannot exceed venue capacity
    const totalTickets = this.calculateTotalTickets() + ticket.getQuantity()
    if (totalTickets > this.schedule.getVenue().getCapacity()) {
      throw new OneJsError(
        'Ticket limit exceeded',
        400,
        'Total tickets cannot exceed venue capacity',
        { 
          totalTickets, 
          capacity: this.schedule.getVenue().getCapacity() 
        },
        ErrorCodes.VALIDATION_FAILED
      )
    }

    // Validate invariant: ticket price must match pricing tier
    if (!this.pricing.isValidTicketPrice(ticket.getPrice())) {
      throw new OneJsError(
        'Invalid ticket price',
        400,
        'Ticket price does not match any pricing tier',
        { price: ticket.getPrice().toString() },
        ErrorCodes.VALIDATION_FAILED
      )
    }

    // Validate invariant: cannot add tickets to cancelled events
    if (this.status.isCancelled()) {
      throw new OneJsError(
        'Cannot add tickets',
        400,
        'Cannot add tickets to cancelled event',
        { eventId: this.id.toString() },
        ErrorCodes.INVALID_STATE
      )
    }

    this.tickets.push(ticket)
  }

  // ... more complex business logic maintaining invariants
  // ... 500+ more lines of aggregate coordination
}
```


**Unit tests for domain layer:**

```typescript
// packages/events/domain/entities/__tests__/event.test.ts

describe('Event Entity - isVerified field', () => {
  test('should create event with isVerified=false by default', () => {
    // Arrange
    const eventData = {
      id: EventId.generate(),
      title: Title.create('Concert'),
      // isVerified not specified
    }
    
    // Act
    const event = Event.create(eventData)
    
    // Assert
    expect(event.getIsVerified()).toBe(false)
  })
  
  test('should create event with isVerified=true', () => {
    // Arrange
    const eventData = {
      id: EventId.generate(),
      title: Title.create('Verified Concert'),
      isVerified: true,
    }
    
    // Act
    const event = Event.create(eventData)
    
    // Assert
    expect(event.getIsVerified()).toBe(true)
  })
  
  test('should include isVerified in DTO', () => {
    // Arrange
    const event = Event.create({
      id: EventId.generate(),
      title: Title.create('Concert'),
      isVerified: true,
    })
    
    // Act
    const dto = event.toDto()
    
    // Assert
    expect(dto.isVerified).toBe(true)
  })
  
  test('should create event from database row with isVerified', () => {
    // Arrange
    const dbRow = {
      id: 'event-123',
      title: 'Concert',
      slug: 'concert',
      isVerified: false,
      // ... other fields
    }
    
    // Act
    const event = Event.fromDatabase(dbRow)
    
    // Assert
    expect(event.getIsVerified()).toBe(false)
  })
})
```

### Example 2: Adding Foreign Key Constraint

**Migration SQL:**

```sql
-- Add cityId foreign key to Event table
ALTER TABLE "Event" 
ADD CONSTRAINT "Event_cityId_fkey" 
FOREIGN KEY ("cityId") 
REFERENCES "City"("id") 
ON DELETE RESTRICT 
ON UPDATE CASCADE;
```

**Required tests:**

```typescript

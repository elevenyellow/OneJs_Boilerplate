# Code Style Guidelines
- don't have to include jsdoc comments
- do avoid type assertions, only when is absolutely necessary
- Let TypeScript infer return types from function implementations, only explicitly declare return types in interfaces and abstract methods.
- Naming: Follow Domain-Driven Design patterns
- Architecture: Application, Domain, Infrastructure layers
- Packages: Monorepo with workspaces in packages/* /apps/*
- Comments Language: Use always english language for comments

## DDD Conventions
- **Use-cases and Application services expose `execute(...): Promise<Output>`** - prefer passing entities or value objects directly when useful; use multiple parameters when it improves clarity and coupling; fallback to single input object for complex cases
- Handlers expose `handle(event): Promise<void|Result>`
- **NEVER return `null` or `undefined`** - throw `OneJsError` for error conditions, return result objects for expected failures
- Prefer entities and value objects as direct parameters; use multiple parameters when useful; single input object for complex grouped cases
- Avoid unnecessary interfaces; use @Injectable/@Inject and add interfaces only for real ports or multiple implementations
- File suffixes: *.use-case.ts, *.service.ts, *.handler.ts, *.repository.ts
- Use injected Logger with MATO:<context>:<feature> prefixes; no console.log

## Commands

- DB client generate: `bun db:generate`
- DB sync: `bun db:push`
- TEST: `TEST_LOGGER=1 bun test <file_path: ex. packages/events/rest-of-the-path>`

## Cheat Sheet

### Use-case and Service pattern (Flexible: prefer entities/value objects, multiple params when useful)
```ts
import { Inject, Injectable } from '@OneJs'
import { OneJsError } from '@OneJs/Core'
import { ErrorCodes } from '@OneJs/shared-errors'

@Injectable()
export class GetTagByIdUseCase {
  constructor(
    @Inject(TagPrismaRepository)
    private readonly tagRepository: TagPrismaRepository,
  ) {}

  // ✅ PREFERRED: Value object as direct parameter
  async execute(tagId: TagId): Promise<Tag> {
    const tag = await this.tagRepository.findById(tagId)
    
    if (!tag) {
      throw new OneJsError(
        'Tag not found',
        404,
        `Tag with id ${tagId.toString()} does not exist`,
        { id: tagId.toString() },
        ErrorCodes.RESOURCE_NOT_FOUND
      )
    }
    
    return tag
  }
}

// ✅ PREFERRED: Multiple parameters with entities/value objects
@Injectable()
export class UpdateTagUseCase {
  async execute(tag: Tag, updateData: UpdateTagDto): Promise<Tag> {
    // Direct entity access - clearer and better coupling
    // ... implementation
  }
}

// ✅ PREFERRED: Multiple value objects as parameters
@Injectable()
export class SearchEventsUseCase {
  async execute(
    cityId: CityId,
    startDate: EventDateTime,
    endDate: EventDateTime,
    page: Page,
    limit: Limit,
    categoryIds?: CategoryId[],
    search?: SearchQuery,
    tags?: TagId[],
    timezone: string
  ): Promise<{ events: Event[]; pagination: PaginationMeta }> {
    // Multiple parameters with value objects - clear and type-safe
    // ... implementation
  }
}

// ✅ VALID: Single input object for complex grouped cases
@Injectable()
export class CreateComplexEntityUseCase {
  async execute(input: {
    entity: Entity
    relatedData: ComplexDto
    options: Options
    metadata: Metadata
  }): Promise<Result> {
    // Single object when structure is complex or needs grouping
    // ... implementation
  }
}

// ✅ VALID: Mix of entities and value objects
@Injectable()
export class ProcessEventUseCase {
  async execute(event: Event, location: City, filters: EventFilters): Promise<void> {
    // Entities and value objects as direct parameters
    // ... implementation
  }
}

// ❌ AVOID: Unnecessary wrapping of single entities
// async execute(input: { tag: Tag }): Promise<Tag> {
//   // ❌ Prefer: async execute(tag: Tag): Promise<Tag>
// }

// ✅ Result object for expected failures
@Injectable()
export class ValidateEmailUseCase {
  async execute(email: Email): Promise<{ success: boolean; reason?: string }> {
    if (await this.emailExists(email)) {
      return { success: false, reason: 'Email already in use' }
    }
    return { success: true }
  }
}
```

### Use-case with event publishing
```ts
import { EventBus } from '@OneJs/EventBus'

@Injectable()
export class CreateCityUseCase {
  constructor(
    @Inject(CityPrismaRepository)
    private readonly cityRepository: CityPrismaRepository,
    @Inject(EventBus)
    private readonly eventBus: EventBus,
  ) {}

  async execute(input: CreateCityDto): Promise<City> {
    const city = City.create({ ...input })
    const savedCity = await this.cityRepository.save(city)
    
    // Publish event after successful persistence
    await this.eventBus.publish(new CreateCityEvent(savedCity.toEventDto()))
    
    return savedCity
  }
}
```

### Event handler pattern
```ts
import { EventHandler } from '@OneJs/EventBus'
import type { DomainEvent } from '@OneJs/EventBus'

@Injectable()
export class CreateCityEventHandler {
  constructor(
    @Inject(SomeUseCase)
    private readonly someUseCase: SomeUseCase,
  ) {}

  @EventHandler(CreateCityEvent)
  async handle(event: CreateCityEvent): Promise<void> {
    // Map event to use case input (can pass entities/value objects directly)
    await this.someUseCase.execute(
      event.data.id, // or pass entity/value object if available
      // ... other parameters
    )
  }
}

// ✅ Idempotent handler example
@EventHandler(NewPostEvent)
async handle(event: NewPostEvent): Promise<void> {
  // Check if already processed
  const processed = await this.eventLogRepository.findByEventId(event.id)
  if (processed) {
    this.logger.debug('MATO:INSTAGRAM:NEW_POST', `Event ${event.id} already processed`)
    return
  }
  
  await this.processPostUseCase.execute({ postId: event.data.id })
  await this.eventLogRepository.markProcessed(event.id)
}
```

### Controller pattern
```ts
import { Controller, Get, Post, Inject, type Context } from '@OneJs'
import { UseAdminRole } from '@OneJs/Auth'

@Controller('/tags')
export class TagsController {
  constructor(
    @Inject(GetTagByIdUseCase)
    private readonly getTagByIdUseCase: GetTagByIdUseCase,
  ) {}

  @Get('/:id')
  async getTagById(ctx: Context) {
    const { id } = ctx.params as { id: string }
    const tagId = TagId.createFrom(id) // Create value object from string
    // Use case throws OneJsError if not found - no null check
    const tag = await this.getTagByIdUseCase.execute(tagId)
    return { tag: tag.toDto() } // Map entity to DTO
  }

  @UseAdminRole()
  @Post('/')
  async create(ctx: Context) {
    const body = ctx.body as CreateTagDto
    const tag = await this.createTagUseCase.execute(body)
    ctx.set.status = 201
    return { tag: tag.toDto() }
  }
}
```

### Error handling in use cases
```ts
import { OneJsError } from '@OneJs/Core'
import { ErrorCodes } from '@OneJs/shared-errors'

@Injectable()
export class SomeUseCase {
  async execute(entityId: EntityId): Promise<SomeEntity> {
    // ✅ Throw for exceptional conditions
    const entity = await this.repository.findById(entityId)
    if (!entity) {
      throw new OneJsError(
        'Resource not found',
        404,
        `Entity with id ${entityId.toString()} does not exist`,
        { id: entityId.toString() },
        ErrorCodes.RESOURCE_NOT_FOUND
      )
    }

    // ✅ Log and transform infrastructure errors
    try {
      await this.repository.save(entity)
    } catch (error) {
      this.logger.error('MATO:CONTEXT:FEATURE', 'Failed to save', { error })
      throw new OneJsError(
        'Operation failed',
        500,
        'Database operation failed',
        { originalError: String(error) },
        ErrorCodes.SERVER_ERROR
      )
    }

    return entity
  }
}
```

### Transaction helper (Prisma)
```ts
import { PrismaClient } from '@prisma/client'

export async function withTransaction<T>(
  prisma: PrismaClient,
  fn: (tx: PrismaClient) => Promise<T>
): Promise<T> {
  return prisma.$transaction(async (tx) => fn(tx))
}

// Usage in use case
async execute(entity1: Entity1, entity2: Entity2): Promise<void> {
  await withTransaction(this.prisma, async (tx) => {
    await this.repository1.save(entity1, tx)
    await this.repository2.save(entity2, tx)
  })
}
```

### Value object creation
```ts
// ✅ Strict validation for user input
const name = CityName.create(input.name) // Validates all rules

// ✅ Trusted input from database
const city = await this.repository.findById(id)
const name = CityName.createFrom(city.name) // Minimal validation
```


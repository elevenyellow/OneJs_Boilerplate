{
  "expo": {
    "jsEngine": "hermes",
    "name": "ClimbZone",
    "slug": "climb-zone",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "climbzone",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#8B5A2B"
    },
    "ios": {
      "jsEngine": "hermes",
      "supportsTablet": true,
      "bundleIdentifier": "com.climbzone.app",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ClimbZone necesita tu ubicación para mostrarte zonas de escalada cercanas."
      }
    },
    "android": {
      "jsEngine": "hermes",
      "package": "com.climbzone.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "ClimbZone necesita tu ubicación para mostrarte zonas de escalada cercanas."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "http://192.168.8.178:4000/api"
    }
  }
}